generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String              @id @default(uuid())
  employeeId      String              @unique
  name            String
  email           String              @unique
  phone           String?
  password        String
  role            UserRole            @default(USER)
  status          UserStatus          @default(INACTIVE)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  lastLogin       DateTime?
  division        String?
  isVerified      Boolean             @default(false)
  rejectedAt      DateTime?
  rejectedBy      String?
  rejectionReason String?
  verifiedAt      DateTime?
  verifiedBy      String?
  resetOtp        String?
  resetOtpExpiry  DateTime?
  priority        Int                 @default(0)
  designation     UserNewDesignation?
  createdShifts   Shift[]             @relation("CreatedBy")
  updatedShifts   Shift[]             @relation("UpdatedBy")

  @@index([employeeId])
  @@index([email])
  @@index([isVerified])
  @@index([status])
  @@map("users")
}

model Staff {
  id            String      @id @default(uuid())
  employeeId    String      @unique
  name          String
  staffType     StaffType
  phone         String?
  email         String?
  homeStation   String?
  status        StaffStatus @default(AVAILABLE)
  autoCreated   Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  division      String?
  dutyLogs      DutyLog[]
  pilotShifts   Shift[]     @relation("LocoPilot")
  managerShifts Shift[]     @relation("TrainManager")

  @@index([employeeId])
  @@index([name])
  @@index([status])
  @@index([staffType])
  @@map("staff")
}

model Locomotive {
  id           String   @id @default(uuid())
  locomotiveNo String   @unique
  status       String?  @default("ACTIVE")
  autoCreated  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  shifts       Shift[]

  @@index([locomotiveNo])
  @@map("locomotives")
}

model Shift {
  id                   String         @id @default(uuid())
  trainNumber          String
  trainName            String?
  locomotiveId         String
  locoPilotId          String
  trainManagerId       String
  timeOfTO             DateTime?
  signOnStation        String
  signOffStation       String?
  section              String
  dutyType             dutyType?
  dutyHours            Float?
  status               ShiftStatus    @default(SCHEDULED)
  reliefRequired       Boolean        @default(false)
  reliefPlanned        Boolean        @default(false)
  reliefTime           DateTime?
  reliefReason         String?
  createdById          String
  updatedById          String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  alert10HrResponse    String?
  alert10HrSent        Boolean        @default(false)
  alert10HrSentAt      DateTime?
  alert11HrResponse    String?
  alert11HrSent        Boolean        @default(false)
  alert11HrSentAt      DateTime?
  alert14HrResponse    String?
  alert14HrSent        Boolean        @default(false)
  alert14HrSentAt      DateTime?
  alert7HrSent         Boolean        @default(false)
  alert7HrSentAt       DateTime?
  alert8HrResponse     String?
  alert8HrSent         Boolean        @default(false)
  alert8HrSentAt       DateTime?
  alert9HrResponse     String?
  alert9HrSent         Boolean        @default(false)
  alert9HrSentAt       DateTime?
  departureDateTime    DateTime?
  signOffDateTime      DateTime?
  signOnDateTime       DateTime
  trainArrivalDateTime DateTime?
  dutyLogs             DutyLog[]
  notifications        Notification[]
  createdBy            User           @relation("CreatedBy", fields: [createdById], references: [id])
  locoPilot            Staff          @relation("LocoPilot", fields: [locoPilotId], references: [id])
  locomotive           Locomotive     @relation(fields: [locomotiveId], references: [id])
  trainManager         Staff          @relation("TrainManager", fields: [trainManagerId], references: [id])
  updatedBy            User?          @relation("UpdatedBy", fields: [updatedById], references: [id])

  @@index([trainNumber])
  @@index([locoPilotId])
  @@index([trainManagerId])
  @@index([status])
  @@index([signOnDateTime])
  @@map("shifts")
}

model DutyLog {
  id             String      @id @default(uuid())
  shiftId        String
  staffId        String
  logType        DutyLogType
  logTime        DateTime    @default(now())
  dutyHoursAtLog Float?
  remarks        String?
  metadata       Json?
  createdAt      DateTime    @default(now())
  shift          Shift       @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  staff          Staff       @relation(fields: [staffId], references: [id])

  @@index([shiftId])
  @@index([staffId])
  @@index([logType])
  @@index([logTime])
  @@map("duty_logs")
}

model Notification {
  id             String             @id @default(uuid())
  shiftId        String
  type           NotificationType
  title          String
  message        String
  dutyHours      Float
  status         NotificationStatus @default(PENDING)
  sentAt         DateTime?
  acknowledgedAt DateTime?
  responseAction String?
  responseTime   DateTime?
  responseBy     String?
  metadata       Json?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  priority       Int                @default(0)
  targetDivision String?
  targetUsers    String[]
  shift          Shift              @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@index([shiftId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("notifications")
}

model SystemConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_config")
}

enum UserRole {
  SUPERADMIN
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserNewDesignation {
  OFFICER
  SUPERVISOR
  CHASER
}

enum StaffType {
  LOCO_PILOT
  TRAIN_MANAGER
}

enum StaffStatus {
  AVAILABLE
  ON_DUTY
  ON_LEAVE
  RELIEVED
  INACTIVE
}

enum ShiftStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  RELIEF_PLANNED
  CANCELLED
}

enum dutyType {
  SP
  WR
  LR
}

enum DutyLogType {
  SIGN_ON
  TAKE_OVER
  DEPARTURE
  MILESTONE
  ALERT_7HR
  ALERT_8HR
  ALERT_9HR
  ALERT_10HR
  ALERT_11HR
  ALERT_14HR
  RELIEF_PLANNED
  RELIEF_NOT_REQUIRED
  CREW_RELIEVED
  CREW_NOT_BOOKED
  KEEP_ON_DUTY
  CREW_ALREADY_RELIEVED
  RELEASE
}

enum NotificationType {
  DUTY_8HR
  DUTY_9HR
  DUTY_11HR
  DUTY_12HR
  DUTY_14HR
  RELIEF_PLANNED
  SHIFT_COMPLETED
  CUSTOM
}

enum NotificationStatus {
  PENDING
  SENT
  ACKNOWLEDGED
  FAILED
}

enum UserDesignation {
  X
  Y
  Z
}
